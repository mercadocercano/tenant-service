# syntax=docker/dockerfile:1
# ==============================================
# Tenant Service — Dev con hot reload (Air)
# Requiere: GITHUB_TOKEN como BuildKit secret para módulos privados (eventbus)
# ==============================================
FROM golang:1.25-alpine

RUN apk add --no-cache git ca-certificates tzdata curl postgresql-client

# Instalar Air (hot reload)
RUN go install github.com/air-verse/air@v1.61.7

WORKDIR /app

ENV GOPRIVATE=github.com/mercadocercano/*

# Descargar dependencias con el token montado como BuildKit secret: solo existe
# durante este RUN y el gitconfig se borra al final → el token NUNCA queda en capas.
COPY go.mod go.sum ./
RUN --mount=type=secret,id=github_token \
    if [ -s /run/secrets/github_token ]; then \
      git config --global url."https://$(cat /run/secrets/github_token)@github.com/".insteadOf "https://github.com/"; \
    fi && \
    go mod download && \
    rm -f /root/.gitconfig

# Copiar fuentes (cambian frecuentemente, van al final)
COPY . .

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8120/health || exit 1

EXPOSE 8120

# Air usa el cache de módulos descargado en la capa anterior
CMD ["air", "-c", ".air.toml"]
